# Flask
FLASK_ENV=development
FLASK_DEBUG=1

# Security (change these in production)
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
JWT_SECRET_KEY=change-this-to-a-random-jwt-secret-min-32-chars

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///debtdz.db
# DATABASE_URL=postgresql://user:password@host:5432/debtdz

# CORS (comma-separated origins)
FLASK_CORS_ORIGINS=http://localhost:5173

# Logging
LOG_LEVEL=DEBUG
